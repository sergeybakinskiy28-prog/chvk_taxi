# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
DRIVER_CHAT_ID=-1001234567890
ADMIN_CHAT_ID=-1001234567890

# PostgreSQL
POSTGRES_USER=chvk
POSTGRES_PASSWORD=chvk_secret
POSTGRES_DB=taxi

# Database: в Docker — db:5432; локально — localhost:5432
DATABASE_URL=postgresql+asyncpg://chvk:chvk_secret@db:5432/taxi

# Backend
SECRET_KEY=your-secret-key-change-in-production

# API_BASE_URL: в Docker — http://api:8000; локально — http://127.0.0.1:8000
API_BASE_URL=http://api:8000
